# Revenue Tooling Configuration Template
# Copy this file and set only the providers you use before running configure-revenue-tools.sh

# =============================================================================
# SENSITIVE SECRETS (Never commit these values)
# =============================================================================

# Stripe (Payment Processing)
# Get your API key from: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Paddle (Payment Processing)
# Get your API key from: https://vendors.paddle.com/authentication
PADDLE_API_KEY="pdl_live_..."

# Gumroad (Digital Products)
# Get your access token from: https://app.gumroad.com/settings/advanced
GUMROAD_ACCESS_TOKEN="..."

# Shopify (E-commerce)
# Get your admin API token from: Shopify Admin → Apps → Develop apps
SHOPIFY_ADMIN_API_TOKEN="shpat_..."

# HubSpot (CRM)
# Get your API key from: https://app.hubspot.com/settings/integrations/api
HUBSPOT_API_KEY="pat-na1-..."

# PostHog (Analytics)
# Get your API key from: https://app.posthog.com/project/settings
POSTHOG_API_KEY="phx_..."

# Slack (Notifications)
# Create a webhook at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."

# =============================================================================
# NON-SENSITIVE CONFIGURATION VARIABLES
# =============================================================================

# Primary billing provider: stripe, paddle, gumroad, or shopify
BILLING_PROVIDER="stripe"

# Environment: production or staging
BILLING_ENVIRONMENT="production"

# CRM provider: hubspot or none
CRM_PROVIDER="hubspot"

# Analytics provider: posthog or none
ANALYTICS_PROVIDER="posthog"

# Default currency code (ISO 4217)
DEFAULT_CURRENCY="USD"

# Minimum balance threshold for alerts (in dollars)
REVENUE_ALERT_THRESHOLD="1000"

# Shopify store domain (required if using Shopify)
# Example: mystore.myshopify.com
SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"

# PostHog instance URL (required if using PostHog)
# Use https://app.posthog.com for PostHog Cloud
POSTHOG_HOST="https://app.posthog.com"

# =============================================================================
# USAGE INSTRUCTIONS
# =============================================================================
#
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Edit .env and fill in your actual credentials
#    (only for the providers you use)
#
# 3. Source the environment file:
#    source .env
#
# 4. Run the configuration script:
#    ./scripts/configure-revenue-tools.sh owner/repo
#
# 5. Verify in GitHub:
#    Go to Settings → Secrets and variables → Actions
#
# =============================================================================
