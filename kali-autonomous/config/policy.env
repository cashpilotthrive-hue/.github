# Required: absolute or repo-relative path to signed authorization artifact.
AUTHORIZATION_FILE=./kali-autonomous/config/authorization.sig

# Required: target allowlist file (one host/CIDR per line; comments with # supported).
TARGET_ALLOWLIST=./kali-autonomous/config/targets.txt

# Automation controls
LOOP_INTERVAL_SECONDS=900
MAX_RUNTIME_SECONDS=0
ENABLE_INTRUSIVE_TESTS=false
RATE_LIMIT_MILLISECONDS=250
