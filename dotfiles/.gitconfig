[user]
	name = Your Name
	email = your.email@example.com

[core]
	editor = vim
	autocrlf = input
	excludesfile = ~/.gitignore_global

[init]
	defaultBranch = main

[color]
	ui = auto

[alias]
	st = status
	co = checkout
	br = branch
	ci = commit
	unstage = reset HEAD --
	last = log -1 HEAD
	visual = log --graph --oneline --decorate --all
	amend = commit --amend
	undo = reset --soft HEAD^

[pull]
	rebase = false

[push]
	default = simple

[credential]
	helper = cache --timeout=3600

[diff]
	tool = vimdiff

[merge]
	tool = vimdiff
	conflictstyle = diff3

[fetch]
	prune = true

[log]
	date = relative
