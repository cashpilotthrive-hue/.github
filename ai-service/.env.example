# AI Service Environment Variables
FLASK_ENV=development
FLASK_APP=src/app.py
PORT=5002

# TensorFlow Configuration
TF_CPP_MIN_LOG_LEVEL=2
TF_ENABLE_ONEDNN_OPTS=0

# Model Paths
IDENTITY_MODEL_PATH=./models/identity_verification_model.h5
FRAUD_MODEL_PATH=./models/fraud_detection_model.h5
DOCUMENT_MODEL_PATH=./models/document_quality_model.h5

# Redis Configuration (for Celery)
REDIS_URL=redis://localhost:6379/0

# Backend API Configuration
BACKEND_API_URL=http://localhost:5000

# Confidence Thresholds
IDENTITY_CONFIDENCE_THRESHOLD=0.85
FRAUD_CONFIDENCE_THRESHOLD=0.75
DOCUMENT_QUALITY_THRESHOLD=0.80

# Security
API_SECRET_KEY=your-secret-key-here-change-in-production
