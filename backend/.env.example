# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crypto_mining_platform
DB_USER=postgres
DB_PASSWORD=your_db_password

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password
EMAIL_FROM=noreply@cryptomining.com

# Blockchain Configuration
WEB3_PROVIDER_URL=https://mainnet.infura.io/v3/your_infura_project_id
ETH_PRIVATE_KEY=your_eth_private_key
BTC_NETWORK=testnet

# Payment Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Withdrawal Configuration
MIN_WITHDRAWAL_AMOUNT=0.001
MAX_WITHDRAWAL_AMOUNT=10
DAILY_WITHDRAWAL_LIMIT=50

# Mining Configuration
MINING_DIFFICULTY_ADJUSTMENT_INTERVAL=2016
BASE_HASH_RATE=1000000

# WebSocket Configuration
WS_PORT=5001

# Admin Configuration
ADMIN_EMAIL=admin@cryptomining.com
SUPER_ADMIN_EMAIL=superadmin@cryptomining.com
